# Variables d'environnement pour Render
# Copier ce fichier en .env pour le développement local
# NE PAS committer les vraies valeurs, utiliser le dashboard Render pour la production

DEBUG=True
SECRET_KEY=your-secret-key-here-generate-a-new-one
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://postgres:password@localhost:5432/reclamation_db
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8100,http://127.0.0.1:8100
